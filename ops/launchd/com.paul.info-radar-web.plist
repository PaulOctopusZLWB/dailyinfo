<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.paul.info-radar-web</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>exec "$HOME/Library/Application Support/InfoRadar/run-web.sh"</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/tmp</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/info-radar-web.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/info-radar-web.err.log</string>
</dict>
</plist>
