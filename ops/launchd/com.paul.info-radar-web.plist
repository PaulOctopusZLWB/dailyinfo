<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.paul.info-radar-web</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/paul/Documents/info_radar &amp;&amp; export INFO_RADAR_ALLOWED_CLIENT_NETS="127.0.0.0/8,::1/128,10.0.0.0/8" &amp;&amp; exec /Users/paul/Documents/info_radar/.venv/bin/python -m info_radar.cli web --host 0.0.0.0 --port 8787 --reports-dir /Users/paul/Documents/info_radar/.info_radar/published --static-dir /Users/paul/Documents/info_radar/web</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/paul/Documents/info_radar</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/paul/Documents/info_radar/.info_radar/logs/web.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/paul/Documents/info_radar/.info_radar/logs/web.err.log</string>
</dict>
</plist>
