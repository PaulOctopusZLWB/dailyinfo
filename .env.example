# Optional source credentials. Copy this file to .env or export values in your shell.
# Never commit real tokens.

# GitHub raises unauthenticated API limits and enables low-priority issue fetches.
GITHUB_TOKEN=

# X Developer Console -> Project/App -> Keys and tokens -> Bearer Token.
# Either variable name works.
X_BEARER_TOKEN=
TWITTER_BEARER_TOKEN=

# Optional runtime paths.
INFO_RADAR_OUTPUT_DIR=.info_radar/reports
INFO_RADAR_REPORTS_DIR=.info_radar/published
INFO_RADAR_STATIC_DIR=web
INFO_RADAR_HOST=0.0.0.0
INFO_RADAR_PORT=8787
INFO_RADAR_ALLOWED_CLIENT_NETS=127.0.0.0/8,::1/128,10.0.0.0/8
